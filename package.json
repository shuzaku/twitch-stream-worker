    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "obs-websocket-js": "^5.0.8",
    "tmi.js": "^1.8.5",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
